---
import Layout from '../../../layouts/Layout.astro';
---

<Layout title="Our Missions" lang="en">
  <!-- Hero -->
  <section class="bg-gradient-to-br from-sante-600 to-sante-700 text-white py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <span class="inline-block bg-white/20 text-sm font-semibold px-4 py-2 rounded-full mb-6">
          Our purpose
        </span>
        <h1 class="text-4xl sm:text-5xl font-extrabold mb-6">
          Our Missions
        </h1>
        <p class="text-xl text-white/90">
          MEDSEN's mission is to guarantee the right to health for every school-age child
          in Senegal, in accordance with the International Convention on the Rights of the Child.
        </p>
      </div>
    </div>
  </section>

  <!-- Main mission -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div>
          <h2 class="text-3xl font-bold text-gray-900 mb-6">
            A national vision for school health
          </h2>
          <p class="text-lg text-gray-600 mb-6">
            Senegal has more than <strong>6 million students</strong> spread across 14 regions.
            Today, their health monitoring relies on fragmented, often paper-based processes
            that do not allow for a comprehensive overview or continuous follow-up.
          </p>
          <p class="text-lg text-gray-600 mb-6">
            MEDSEN offers a <strong>unified digital platform</strong> that connects schools,
            School Medical Inspectorates (IME), families, and health authorities.
          </p>
          <div class="bg-sante-50 border-l-4 border-sante-500 p-6 rounded-r-lg">
            <p class="text-sante-800 font-medium italic">
              "Every child has the right to the highest attainable standard of health
              and to access health services."
            </p>
            <p class="text-sante-600 text-sm mt-2">— Article 24, Convention on the Rights of the Child</p>
          </div>
        </div>
        <div class="bg-gray-100 rounded-2xl p-8">
          <h3 class="text-xl font-bold text-gray-900 mb-6">Our measurable objectives</h3>
          <div class="space-y-6">
            <div class="flex items-center gap-4">
              <div class="w-16 h-16 bg-sante-500 rounded-xl flex items-center justify-center text-white font-bold text-xl">
                100%
              </div>
              <div>
                <div class="font-semibold text-gray-900">Vaccination coverage</div>
                <div class="text-gray-600">According to the national immunization schedule</div>
              </div>
            </div>
            <div class="flex items-center gap-4">
              <div class="w-16 h-16 bg-blue-500 rounded-xl flex items-center justify-center text-white font-bold text-xl">
                100%
              </div>
              <div>
                <div class="font-semibold text-gray-900">Mandatory health assessments</div>
                <div class="text-gray-600">At ages 3, 6, and 12 for every child</div>
              </div>
            </div>
            <div class="flex items-center gap-4">
              <div class="w-16 h-16 bg-purple-500 rounded-xl flex items-center justify-center text-white font-bold text-xl">
                0
              </div>
              <div>
                <div class="font-semibold text-gray-900">Children left behind</div>
                <div class="text-gray-600">Every student in the health system</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- The 5 missions -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-4">
          Five fundamental missions
        </h2>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          Each mission addresses a concrete need and falls within the legal framework
          of the Convention on the Rights of the Child.
        </p>
      </div>

      <div class="space-y-8">
        <!-- Mission 1 -->
        <div class="bg-white rounded-2xl p-8 shadow-sm">
          <div class="flex flex-col md:flex-row gap-8">
            <div class="w-20 h-20 bg-sante-100 rounded-2xl flex items-center justify-center flex-shrink-0">
              <span class="text-3xl font-bold text-sante-600">1</span>
            </div>
            <div>
              <h3 class="text-2xl font-bold text-gray-900 mb-4">Prevention and early screening</h3>
              <p class="text-gray-600 mb-4">
                Organize systematic health assessments at key ages (3, 6, 9, 12, 15 years)
                and screening campaigns (visual, auditory, dental, nutritional)
                to identify problems before they impact schooling.
              </p>
              <div class="flex flex-wrap gap-2">
                <span class="bg-sante-100 text-sante-700 text-sm px-3 py-1 rounded-full">Mandatory assessments</span>
                <span class="bg-sante-100 text-sante-700 text-sm px-3 py-1 rounded-full">Screenings</span>
                <span class="bg-sante-100 text-sante-700 text-sm px-3 py-1 rounded-full">Growth charts</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Mission 2 -->
        <div class="bg-white rounded-2xl p-8 shadow-sm">
          <div class="flex flex-col md:flex-row gap-8">
            <div class="w-20 h-20 bg-blue-100 rounded-2xl flex items-center justify-center flex-shrink-0">
              <span class="text-3xl font-bold text-blue-600">2</span>
            </div>
            <div>
              <h3 class="text-2xl font-bold text-gray-900 mb-4">Vaccination and immunization</h3>
              <p class="text-gray-600 mb-4">
                Monitor the vaccination status of every student according to Senegal's Expanded Programme
                on Immunization (EPI). Identify delays, organize catch-up sessions, and ensure vaccination coverage.
              </p>
              <div class="flex flex-wrap gap-2">
                <span class="bg-blue-100 text-blue-700 text-sm px-3 py-1 rounded-full">Digital vaccination record</span>
                <span class="bg-blue-100 text-blue-700 text-sm px-3 py-1 rounded-full">Delay alerts</span>
                <span class="bg-blue-100 text-blue-700 text-sm px-3 py-1 rounded-full">Vaccination campaigns</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Mission 3 -->
        <div class="bg-white rounded-2xl p-8 shadow-sm">
          <div class="flex flex-col md:flex-row gap-8">
            <div class="w-20 h-20 bg-purple-100 rounded-2xl flex items-center justify-center flex-shrink-0">
              <span class="text-3xl font-bold text-purple-600">3</span>
            </div>
            <div>
              <h3 class="text-2xl font-bold text-gray-900 mb-4">Inclusion of children with special needs</h3>
              <p class="text-gray-600 mb-4">
                Identify and support students with special needs: disabilities, learning disorders,
                chronic illnesses. Implement IAPs (Individualized Accommodation Plans)
                and PSPs (Personalized Schooling Projects).
              </p>
              <div class="flex flex-wrap gap-2">
                <span class="bg-purple-100 text-purple-700 text-sm px-3 py-1 rounded-full">IAP</span>
                <span class="bg-purple-100 text-purple-700 text-sm px-3 py-1 rounded-full">PSP</span>
                <span class="bg-purple-100 text-purple-700 text-sm px-3 py-1 rounded-full">Specialized referrals</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Mission 4 -->
        <div class="bg-white rounded-2xl p-8 shadow-sm">
          <div class="flex flex-col md:flex-row gap-8">
            <div class="w-20 h-20 bg-amber-100 rounded-2xl flex items-center justify-center flex-shrink-0">
              <span class="text-3xl font-bold text-amber-600">4</span>
            </div>
            <div>
              <h3 class="text-2xl font-bold text-gray-900 mb-4">Child protection</h3>
              <p class="text-gray-600 mb-4">
                Establish a reporting system for concerning situations (abuse, neglect,
                danger) with a secure pathway to the appropriate services. Train staff to recognize
                warning signs.
              </p>
              <div class="flex flex-wrap gap-2">
                <span class="bg-amber-100 text-amber-700 text-sm px-3 py-1 rounded-full">Secure reporting</span>
                <span class="bg-amber-100 text-amber-700 text-sm px-3 py-1 rounded-full">Case follow-up</span>
                <span class="bg-amber-100 text-amber-700 text-sm px-3 py-1 rounded-full">Social services coordination</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Mission 5 -->
        <div class="bg-white rounded-2xl p-8 shadow-sm">
          <div class="flex flex-col md:flex-row gap-8">
            <div class="w-20 h-20 bg-teal-100 rounded-2xl flex items-center justify-center flex-shrink-0">
              <span class="text-3xl font-bold text-teal-600">5</span>
            </div>
            <div>
              <h3 class="text-2xl font-bold text-gray-900 mb-4">Monitoring and decision support</h3>
              <p class="text-gray-600 mb-4">
                Provide health and education authorities with real-time dashboards
                to steer school health policy at the local, regional, and national levels.
                Produce the reports required for CRC monitoring.
              </p>
              <div class="flex flex-wrap gap-2">
                <span class="bg-teal-100 text-teal-700 text-sm px-3 py-1 rounded-full">Real-time statistics</span>
                <span class="bg-teal-100 text-teal-700 text-sm px-3 py-1 rounded-full">CRC indicators</span>
                <span class="bg-teal-100 text-teal-700 text-sm px-3 py-1 rounded-full">Automated reports</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-sante-600">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold text-white mb-6">
        Together, let's guarantee every child's right to health
      </h2>
      <p class="text-xl text-white/90 mb-8">
        MEDSEN is ready to be deployed. Contact us for a demonstration
        or to discuss a partnership.
      </p>
      <a href="/en/contact" class="inline-block bg-white text-sante-600 hover:bg-gray-100 px-8 py-4 rounded-xl font-semibold text-lg transition-colors">
        Contact us
      </a>
    </div>
  </section>
</Layout>
