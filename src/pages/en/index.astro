---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Home" lang="en">
  <!-- Hero Section -->
  <section class="relative bg-gradient-to-br from-sante-600 via-sante-500 to-sante-400 text-white overflow-hidden">
    <!-- Background Pattern -->
    <div class="absolute inset-0 opacity-10">
      <svg class="w-full h-full" viewBox="0 0 100 100" preserveAspectRatio="none">
        <defs>
          <pattern id="grid" width="10" height="10" patternUnits="userSpaceOnUse">
            <path d="M 10 0 L 0 0 0 10" fill="none" stroke="white" stroke-width="0.5"/>
          </pattern>
        </defs>
        <rect width="100%" height="100%" fill="url(#grid)" />
      </svg>
    </div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 lg:py-32">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <div class="inline-flex items-center gap-2 bg-white/20 backdrop-blur-sm rounded-full px-4 py-2 mb-6">
            <span class="w-2 h-2 bg-senegal-yellow rounded-full animate-pulse"></span>
            <span class="text-sm font-medium">Senegalese editor · B2G solution for Africa</span>
          </div>

          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold leading-tight mb-6">
            School health,<br/>
            <span class="text-senegal-yellow">finally managed as a system.</span>
          </h1>

          <p class="text-xl text-white/90 mb-8 max-w-xl">
            MEDSEN is the digital solution built by a private Senegalese company,
            designed for <strong>ministries, local authorities and institutions</strong> who want to run
            school health at national scale.
            Built in Senegal, deployable across Africa.
          </p>

          <div class="flex flex-col sm:flex-row gap-4">
            <a href="/en/demo" class="bg-white text-sante-600 hover:bg-gray-100 px-8 py-4 rounded-xl font-semibold text-lg transition-colors text-center">
              Request a demo
            </a>
            <a href="/en/features" class="border-2 border-white text-white hover:bg-white/10 px-8 py-4 rounded-xl font-semibold text-lg transition-colors text-center">
              Explore the solution
            </a>
          </div>

          <!-- Stats mobile only -->
          <div class="grid grid-cols-4 gap-2 mt-8 lg:hidden">
            <div class="text-center">
              <div class="text-2xl font-extrabold text-senegal-yellow">6M+</div>
              <div class="text-[10px] text-white/70">Students Senegal</div>
            </div>
            <div class="text-center">
              <div class="text-2xl font-extrabold text-senegal-yellow">14</div>
              <div class="text-[10px] text-white/70">Regions</div>
            </div>
            <div class="text-center">
              <div class="text-2xl font-extrabold text-senegal-yellow">+15</div>
              <div class="text-[10px] text-white/70">Target countries</div>
            </div>
            <div class="text-center">
              <div class="text-2xl font-extrabold text-senegal-yellow">100%</div>
              <div class="text-[10px] text-white/70">Sovereign</div>
            </div>
          </div>
        </div>

        <div class="hidden lg:block">
          <div class="relative">
            <!-- Decorative circles -->
            <div class="absolute -top-8 -right-8 w-64 h-64 bg-senegal-yellow/20 rounded-full blur-3xl"></div>
            <div class="absolute -bottom-8 -left-8 w-48 h-48 bg-white/20 rounded-full blur-3xl"></div>

            <!-- Stats Card -->
            <div class="relative bg-white/10 backdrop-blur-lg rounded-3xl p-8 border border-white/20">
              <div class="grid grid-cols-2 gap-6">
                <div class="text-center p-4">
                  <div class="text-4xl font-extrabold text-senegal-yellow">6M+</div>
                  <div class="text-sm text-white/80 mt-1">Students in Senegal</div>
                </div>
                <div class="text-center p-4">
                  <div class="text-4xl font-extrabold text-senegal-yellow">14</div>
                  <div class="text-sm text-white/80 mt-1">Regions covered</div>
                </div>
                <div class="text-center p-4">
                  <div class="text-4xl font-extrabold text-senegal-yellow">+15</div>
                  <div class="text-sm text-white/80 mt-1">African countries targeted</div>
                </div>
                <div class="text-center p-4">
                  <div class="text-4xl font-extrabold text-senegal-yellow">100%</div>
                  <div class="text-sm text-white/80 mt-1">Sovereign hosting</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Wave separator -->
    <div class="absolute bottom-0 left-0 right-0">
      <svg viewBox="0 0 1440 120" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0 120L60 110C120 100 240 80 360 70C480 60 600 60 720 65C840 70 960 80 1080 85C1200 90 1320 90 1380 90L1440 90V120H1380C1320 120 1200 120 1080 120C960 120 840 120 720 120C600 120 480 120 360 120C240 120 120 120 60 120H0Z" fill="white"/>
      </svg>
    </div>
  </section>

  <!-- Problem + Solution -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 items-start">
        <div>
          <span class="inline-block bg-red-50 text-red-700 text-sm font-semibold px-4 py-2 rounded-full mb-4">The problem</span>
          <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-6">
            African school health is still managed on paper.
          </h2>
          <ul class="space-y-4 text-gray-600 text-lg">
            <li class="flex gap-3"><span class="text-red-500 font-bold">·</span> No unified digital record to track a child from age 3 to 18.</li>
            <li class="flex gap-3"><span class="text-red-500 font-bold">·</span> National statistics unavailable or out of date.</li>
            <li class="flex gap-3"><span class="text-red-500 font-bold">·</span> Vaccination and screening campaigns untraceable.</li>
            <li class="flex gap-3"><span class="text-red-500 font-bold">·</span> No coordination between schools, health inspectors and parents.</li>
          </ul>
        </div>
        <div>
          <span class="inline-block bg-sante-50 text-sante-700 text-sm font-semibold px-4 py-2 rounded-full mb-4">Our solution</span>
          <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-6">
            A turnkey SaaS platform, ready to deploy.
          </h2>
          <ul class="space-y-4 text-gray-600 text-lg">
            <li class="flex gap-3"><span class="text-sante-500 font-bold">✓</span> Unified Student Health Record, from kindergarten to high school.</li>
            <li class="flex gap-3"><span class="text-sante-500 font-bold">✓</span> Real-time dashboards — local, regional, national.</li>
            <li class="flex gap-3"><span class="text-sante-500 font-bold">✓</span> Workflows between schools, health inspectorates and families.</li>
            <li class="flex gap-3"><span class="text-sante-500 font-bold">✓</span> Sovereign hosting, compliant with government requirements.</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Who is it for: B2G targets -->
  <section class="py-20 bg-gradient-to-br from-gray-50 to-sante-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <span class="inline-block bg-sante-100 text-sante-700 text-sm font-semibold px-4 py-2 rounded-full mb-4">Who is it for</span>
        <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-4">
          Built for public and institutional buyers.
        </h2>
        <p class="text-lg text-gray-600 max-w-3xl mx-auto">
          MEDSEN is designed to meet the contractual, security and budgetary requirements
          of large organizations responsible for child health.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        <div class="bg-white rounded-2xl p-7 shadow-sm border border-gray-100">
          <div class="w-12 h-12 bg-senegal-green/10 rounded-xl flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-senegal-green" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 21h18M3 10h18M5 6l7-3 7 3M4 10v11m16-11v11M8 14v3m4-3v3m4-3v3"/></svg>
          </div>
          <h3 class="font-bold text-gray-900 text-lg mb-2">Ministries & governments</h3>
          <p class="text-gray-600 text-sm mb-4">
            Ministries of Education, Health, Family and Early Childhood.
            Inspectorates, regional health directorates.
          </p>
          <div class="text-xs text-gray-500 font-medium">Senegal · Côte d'Ivoire · Mali · Burkina Faso · Benin · Togo</div>
        </div>

        <div class="bg-white rounded-2xl p-7 shadow-sm border border-gray-100">
          <div class="w-12 h-12 bg-blue-100 rounded-xl flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <h3 class="font-bold text-gray-900 text-lg mb-2">Donors & institutions</h3>
          <p class="text-gray-600 text-sm mb-4">
            UNICEF, WHO, World Bank, AFD, GAVI, Global Fund.
            To finance or co-finance national rollouts of modern school health systems.
          </p>
          <div class="text-xs text-gray-500 font-medium">Multi-country · SDG 3 & 4 indicators</div>
        </div>

        <div class="bg-white rounded-2xl p-7 shadow-sm border border-gray-100">
          <div class="w-12 h-12 bg-purple-100 rounded-xl flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
          </div>
          <h3 class="font-bold text-gray-900 text-lg mb-2">NGOs & school networks</h3>
          <p class="text-gray-600 text-sm mb-4">
            Save the Children, Plan International, Aide & Action, Educo, plus private and
            faith-based school networks looking to professionalize their health monitoring.
          </p>
          <div class="text-xs text-gray-500 font-medium">Multi-site · Donor reporting</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Pan-African ambition -->
  <section class="py-20 bg-gradient-to-br from-sante-700 to-sante-800 text-white relative overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <svg class="w-full h-full" viewBox="0 0 100 100" preserveAspectRatio="none">
        <circle cx="50" cy="50" r="40" fill="none" stroke="white" stroke-width="0.3"/>
        <circle cx="50" cy="50" r="30" fill="none" stroke="white" stroke-width="0.3"/>
        <circle cx="50" cy="50" r="20" fill="none" stroke="white" stroke-width="0.3"/>
      </svg>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <span class="inline-block bg-senegal-yellow text-gray-900 text-sm font-bold px-4 py-2 rounded-full mb-4">Ambition</span>
          <h2 class="text-3xl sm:text-4xl font-bold mb-6">
            Built in Senegal,<br/>designed for <span class="text-senegal-yellow">all of Africa</span>.
          </h2>
          <p class="text-lg text-white/85 mb-6">
            Africa has more than <strong>500 million school-age children</strong> and almost every
            country shares the same problem: no national digital school health solution.
            MEDSEN was architected from day one to be <strong>multi-country, multi-language, multi-curriculum</strong>.
          </p>
          <ul class="space-y-3 text-white/90">
            <li class="flex gap-3"><span class="text-senegal-yellow font-bold">→</span> Multi-tenant: one deployment per country, isolated data.</li>
            <li class="flex gap-3"><span class="text-senegal-yellow font-bold">→</span> Localization: French, English, Portuguese, local languages.</li>
            <li class="flex gap-3"><span class="text-senegal-yellow font-bold">→</span> Configurable reference data (school cycles, national EPI vaccines).</li>
            <li class="flex gap-3"><span class="text-senegal-yellow font-bold">→</span> Local hosting available (data sovereignty).</li>
          </ul>
        </div>
        <div>
          <div class="bg-white/10 backdrop-blur-lg rounded-3xl p-8 border border-white/20">
            <div class="text-center mb-6">
              <div class="text-5xl font-extrabold text-senegal-yellow">+15</div>
              <div class="text-white/80">African countries targeted in 5 years</div>
            </div>
            <div class="grid grid-cols-2 gap-3 text-sm">
              <div class="bg-white/10 rounded-lg px-3 py-2">🇸🇳 Senegal</div>
              <div class="bg-white/10 rounded-lg px-3 py-2">🇨🇮 Côte d'Ivoire</div>
              <div class="bg-white/10 rounded-lg px-3 py-2">🇲🇱 Mali</div>
              <div class="bg-white/10 rounded-lg px-3 py-2">🇧🇫 Burkina Faso</div>
              <div class="bg-white/10 rounded-lg px-3 py-2">🇧🇯 Benin</div>
              <div class="bg-white/10 rounded-lg px-3 py-2">🇹🇬 Togo</div>
              <div class="bg-white/10 rounded-lg px-3 py-2">🇬🇳 Guinea</div>
              <div class="bg-white/10 rounded-lg px-3 py-2">🇳🇪 Niger</div>
              <div class="bg-white/10 rounded-lg px-3 py-2">🇨🇲 Cameroon</div>
              <div class="bg-white/10 rounded-lg px-3 py-2">🇲🇦 Morocco</div>
              <div class="bg-white/10 rounded-lg px-3 py-2">🇷🇼 Rwanda</div>
              <div class="bg-white/10 rounded-lg px-3 py-2 text-white/60">+ more</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Institutional Partnership -->
  <section class="py-16 bg-gradient-to-r from-sante-50 via-white to-senegal-yellow/10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <span class="inline-block bg-senegal-green/10 text-senegal-green text-sm font-semibold px-4 py-2 rounded-full mb-4">
          Official Partnership
        </span>
        <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
          A project supported by institutions
        </h2>
      </div>

      <div class="grid md:grid-cols-2 gap-8 items-center">
        <!-- DCMS Charter -->
        <div class="bg-white rounded-2xl p-8 shadow-lg border-l-4 border-senegal-green">
          <div class="flex items-start gap-4">
            <div class="w-16 h-16 bg-senegal-green/10 rounded-xl flex items-center justify-center flex-shrink-0">
              <svg class="w-8 h-8 text-senegal-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
              </svg>
            </div>
            <div>
              <div class="text-sm font-semibold text-senegal-green mb-1">Project charter signed</div>
              <h3 class="text-xl font-bold text-gray-900 mb-2">Division of School Medical Control (DCMS)</h3>
              <p class="text-gray-600 mb-4">
                MEDSEN has signed a project charter with the DCMS of the Ministry of National Education,
                officially validating our approach and shared objectives for student health.
              </p>
              <div class="flex items-center gap-2 text-sm text-gray-500">
                <svg class="w-4 h-4 text-senegal-green" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
                <span>Ministry of National Education</span>
              </div>
            </div>
          </div>
        </div>

        <!-- IME Dakar Collaboration -->
        <div class="bg-white rounded-2xl p-8 shadow-lg border-l-4 border-sante-500">
          <div class="flex items-start gap-4">
            <div class="w-16 h-16 bg-sante-100 rounded-xl flex items-center justify-center flex-shrink-0">
              <svg class="w-8 h-8 text-sante-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
              </svg>
            </div>
            <div>
              <div class="text-sm font-semibold text-sante-600 mb-1">Active collaboration</div>
              <h3 class="text-xl font-bold text-gray-900 mb-2">School Medical Inspection of Dakar</h3>
              <p class="text-gray-600 mb-4">
                Close collaboration with the Head of the Dakar IME allows us to design
                MEDSEN as close as possible to field realities and the needs of school health professionals.
              </p>
              <div class="flex items-center gap-2 text-sm text-gray-500">
                <svg class="w-4 h-4 text-sante-600" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
                <span>Regular exchanges and field feedback</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Legitimacy banner -->
      <div class="mt-10 text-center">
        <div class="inline-flex flex-col sm:flex-row items-center gap-3 sm:gap-6 bg-gray-50 px-6 sm:px-8 py-4 rounded-2xl sm:rounded-full">
          <div class="flex items-center gap-2">
            <div class="w-3 h-3 bg-senegal-green rounded-full"></div>
            <span class="text-sm text-gray-600">Validated by DCMS</span>
          </div>
          <div class="hidden sm:block w-px h-6 bg-gray-300"></div>
          <div class="flex items-center gap-2">
            <div class="w-3 h-3 bg-senegal-yellow rounded-full"></div>
            <span class="text-sm text-gray-600">Co-designed with IME</span>
          </div>
          <div class="hidden sm:block w-px h-6 bg-gray-300"></div>
          <div class="flex items-center gap-2">
            <div class="w-3 h-3 bg-senegal-red rounded-full"></div>
            <span class="text-sm text-gray-600">Made in Senegal</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CRC Section -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <span class="inline-block bg-sante-100 text-sante-700 text-sm font-semibold px-4 py-2 rounded-full mb-4">
          Legal Foundation
        </span>
        <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-4">
          Rooted in the Rights of the Child
        </h2>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          MEDSEN translates Senegal's commitments to the International Convention
          on the Rights of the Child, ratified in 1990, into concrete actions.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        <!-- Article 24 -->
        <div class="bg-gradient-to-br from-sante-50 to-white rounded-2xl p-8 border border-sante-100 hover:shadow-lg transition-shadow">
          <div class="w-14 h-14 bg-sante-500 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
            </svg>
          </div>
          <div class="text-sm font-semibold text-sante-600 mb-2">Article 24</div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Right to health</h3>
          <p class="text-gray-600">
            Systematic health check-ups, vaccinations, early screenings, and access to care
            for all students without discrimination.
          </p>
        </div>

        <!-- Article 23 -->
        <div class="bg-gradient-to-br from-blue-50 to-white rounded-2xl p-8 border border-blue-100 hover:shadow-lg transition-shadow">
          <div class="w-14 h-14 bg-blue-500 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
            </svg>
          </div>
          <div class="text-sm font-semibold text-blue-600 mb-2">Article 23</div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Rights of children with disabilities</h3>
          <p class="text-gray-600">
            Identification of specific needs, Individualized Accommodation Plans (PAI)
            and Personalized Schooling Projects (PPS).
          </p>
        </div>

        <!-- Article 19 -->
        <div class="bg-gradient-to-br from-amber-50 to-white rounded-2xl p-8 border border-amber-100 hover:shadow-lg transition-shadow">
          <div class="w-14 h-14 bg-amber-500 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
