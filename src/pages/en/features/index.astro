---
import Layout from '../../../layouts/Layout.astro';

// List of features with their CRC (Convention on the Rights of the Child) links
const features = [
  {
    id: 'student-record',
    titre: 'Student Health Record',
    cide: 'Article 24 - Right to health',
    description: 'A comprehensive digital record for each student with their complete school medical history, accessible to authorized professionals.',
    details: [
      'Identity, emergency contacts and legal guardians',
      'Emergency card: allergies, treatments, chronic diseases',
      'Health assessment history (ages 3, 6, 9, 12, 15)',
      'Digital vaccination booklet compliant with EPI',
      'Tabs: Prevention, Development, Inclusion, Consultations'
    ],
    roles: ['IME Doctor', 'Nurse', 'Medical staff'],
    color: 'emerald',
    icon: 'user-card'
  },
  {
    id: 'requests',
    titre: 'School \u2192 IME Request Workflow',
    cide: 'Article 24 - Access to care',
    description: 'Complete workflow for authorization, consultation or referral requests sent by schools to IMEs.',
    details: [
      'Request creation with priority level (Emergency, High, Medium, Low)',
      'Types: Care authorization, PAI, Accommodation, Referral',
      'Real-time status tracking (Pending, Under review, Approved, Rejected)',
      'Assignment to the relevant department and practitioner',
      'Dashboard with counters by status'
    ],
    roles: ['School Principal', 'IME Secretariat', 'Doctor'],
    color: 'purple',
    icon: 'workflow'
  },
  {
    id: 'consultations',
    titre: 'Medical Consultations',
    cide: 'Article 24 - Health care',
    description: 'Complete module for conducting and monitoring medical consultations within IMEs.',
    details: [
      'Types: By appointment, Walk-in, Emergency',
      'Search by student, reason, practitioner',
      'Filtering by date, type and status',
      'Statuses: Scheduled, In progress, Completed, Cancelled',
      'Generation of certificates and prescriptions'
    ],
    roles: ['IME Doctor', 'IME Nurse'],
    color: 'blue',
    icon: 'stethoscope'
  },
  {
    id: 'pai-pps',
    titre: 'PAI and PPS - Inclusion',
    cide: 'Article 23 - Rights of children with disabilities',
    description: 'Management of Individualized Accommodation Plans (PAI) and Personalized Schooling Projects (PPS) for students with specific needs.',
    details: [
      'PAI: Asthma, Diabetes, Allergies, Epilepsy...',
      'Integrated care and emergency protocol',
      'PPS with detailed school accommodations',
      'Validity date tracking and renewals',
      'Coordination with specialized facilities'
    ],
    roles: ['Doctor', 'Principal', 'Educational team'],
    color: 'indigo',
    icon: 'heart-hand'
  },
  {
    id: 'vaccinations',
    titre: 'Vaccination Tracking',
    cide: 'Article 24 - Prevention',
    description: 'Digital vaccination booklet compliant with Senegal\'s Expanded Programme on Immunization (EPI).',
    details: [
      'Visualization of each student\'s vaccination status',
      'Automatically calculated compliance (%)',
      'Alerts for delayed or upcoming vaccinations',
      'History with dates, batches and practitioners',
      'Coverage statistics by school/region'
    ],
    roles: ['Doctor', 'Nurse', 'Campaign coordinator'],
    color: 'green',
    icon: 'syringe'
  },
  {
    id: 'assessments',
    titre: 'Health Assessments',
    cide: 'Article 24 - Early screening',
    description: 'Organization of mandatory health assessments with systematic screenings.',
    details: [
      'Assessments at key ages: 3, 6, 9, 12, 15 years',
      'Screenings: Vision, Hearing, Scoliosis, Dental',
      'Measurements: Height, Weight, BMI with automatic alerts',
      'Growth curves (WHO percentiles)',
      'Referrals to specialists when necessary'
    ],
    roles: ['IME Doctor', 'Nurse'],
    color: 'teal',
    icon: 'clipboard-check'
  },
  {
    id: 'supervision',
    titre: 'National Supervision',
    cide: 'Article 4 - Implementation of rights',
    description: 'Analytical dashboards to manage school health at the IME, regional and national levels.',
    details: [
      'National KPIs: students covered, schools, IMEs, staff',
      'Key indicators vs targets (vaccination coverage, assessments, CFEE visits)',
      'National alerts: struggling regions, shortages',
      'Interactive map with coverage by region',
      'Report generation for the Ministry and the UN (CRC)'
    ],
    roles: ['National supervisor', 'Regional coordinator', 'Ministry'],
    color: 'slate',
    icon: 'chart-bar'
  },
  {
    id: 'parent-portal',
    titre: 'Parent Portal',
    cide: 'Article 12 - Right to be heard',
    description: 'Dedicated space for parents to monitor their children\'s health and communicate with the medical team.',
    details: [
      'View of each child\'s health booklet',
      'Notifications for appointments and vaccinations',
      'Response to consent requests',
      'Consultation history',
      'Secure messaging with the medical team'
    ],
    roles: ['Parent / Guardian'],
    color: 'cyan',
    icon: 'users'
  },
  {
    id: 'protection',
    titre: 'Child Protection',
    cide: 'Article 19 - Protection from violence',
    description: 'Secure reporting system for concerning situations (abuse, neglect, danger).',
    details: [
      'Confidential reporting with urgency level',
      'Secure circuit to the relevant services',
      'Follow-up of case management',
      'History of actions taken',
      'Coordination with social services'
    ],
    roles: ['All authorized staff'],
    color: 'red',
    icon: 'shield'
  }
];
---

<Layout title="Features" lang="en">
  <!-- Hero -->
  <section class="bg-gradient-to-br from-sante-600 to-sante-700 text-white py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <span class="inline-block bg-white/20 text-sm font-semibold px-4 py-2 rounded-full mb-6">
          Discover the platform
        </span>
        <h1 class="text-4xl sm:text-5xl font-extrabold mb-6">
          MEDSEN Features
        </h1>
        <p class="text-xl text-white/90">
          A comprehensive platform covering the entire school health journey,
          aligned with the International Convention on the Rights of the Child.
        </p>
      </div>
    </div>
  </section>

  <!-- Quick navigation -->
  <section class="bg-white border-b border-gray-200 sticky top-20 z-40">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex gap-4 py-4 overflow-x-auto">
        {features.slice(0, 5).map((f) => (
          <a href={`#${f.id}`} class="text-sm font-medium text-gray-600 hover:text-sante-600 whitespace-nowrap transition-colors">
            {f.titre.split(' ')[0]}
          </a>
        ))}
        <span class="text-gray-300">|</span>
        <a href="#supervision" class="text-sm font-medium text-sante-600 whitespace-nowrap">
          Supervision &rarr;
        </a>
      </div>
    </div>
  </section>

  <!-- Detailed features -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="space-y-32">

        <!-- STUDENT RECORD -->
        <div id="student-record" class="scroll-mt-32">
          <div class="grid lg:grid-cols-2 gap-12 items-start">
            <div>
              <div class="inline-flex items-center gap-2 bg-emerald-100 text-emerald-700 text-sm font-semibold px-4 py-2 rounded-full mb-4">
                <span class="w-2 h-2 bg-emerald-500 rounded-full"></span>
                {features[0].cide}
              </div>
              <h2 class="text-3xl font-bold text-gray-900 mb-4">{features[0].titre}</h2>
              <p class="text-lg text-gray-600 mb-6">{features[0].description}</p>
              <ul class="space-y-3 mb-6">
                {features[0].details.map((detail) => (
                  <li class="flex items-start gap-3">
                    <svg class="w-5 h-5 text-emerald-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                    </svg>
                    <span class="text-gray-700">{detail}</span>
                  </li>
                ))}
              </ul>
              <div class="flex flex-wrap gap-2">
                {features[0].roles.map((role) => (
                  <span class="bg-gray-200 text-gray-700 text-xs font-medium px-3 py-1 rounded-full">{role}</span>
                ))}
              </div>
            </div>
            <!-- Student Record Mockup -->
            <div class="bg-white rounded-2xl shadow-xl overflow-hidden">
              <div class="bg-gray-100 px-4 py-3 flex items-center gap-2 border-b">
                <div class="flex gap-1.5">
                  <div class="w-3 h-3 bg-red-400 rounded-full"></div>
                  <div class="w-3 h-3 bg-yellow-400 rounded-full"></div>
                  <div class="w-3 h-3 bg-green-400 rounded-full"></div>
                </div>
                <div class="flex-1 text-center">
                  <span class="text-xs text-gray-500">app.medsen.sn/students/12345</span>
                </div>
              </div>
              <div class="p-4 sm:p-6 bg-gray-50">
                <!-- Student header -->
                <div class="bg-white rounded-xl p-3 sm:p-4 shadow-sm mb-4">
                  <div class="flex items-start gap-3 sm:gap-4">
                    <div class="w-12 h-12 sm:w-16 sm:h-16 bg-gradient-to-br from-emerald-400 to-emerald-600 rounded-xl flex items-center justify-center flex-shrink-0">
                      <span class="text-lg sm:text-xl font-bold text-white">AD</span>
                    </div>
                    <div class="flex-1 min-w-0">
                      <h3 class="text-base sm:text-lg font-bold text-gray-900">Awa Diallo</h3>
                      <p class="text-xs sm:text-sm text-gray-500">12 years old - 5th grade</p>
                      <p class="text-xs text-gray-400 hidden sm:block">CEM Mariama Ba, Dakar</p>
                      <div class="flex flex-wrap gap-1 sm:gap-2 mt-2">
                        <span class="bg-red-100 text-red-700 text-[10px] sm:text-xs px-2 py-0.5 rounded-full">Allergies: Peanuts</span>
                        <span class="bg-orange-100 text-orange-700 text-[10px] sm:text-xs px-2 py-0.5 rounded-full">Active PAI</span>
                      </div>
                    </div>
                    <div class="text-right text-xs text-gray-400 hidden sm:block">
                      <div>SIN</div>
                      <div class="font-mono">SN-2014-DKR-12345</div>
                    </div>
                  </div>
                </div>
                <!-- Tabs -->
                <div class="overflow-x-auto -mx-4 sm:mx-0 px-4 sm:px-0 mb-4">
                  <div class="flex gap-1 bg-white rounded-lg p-1 min-w-max">
                    <button class="bg-emerald-500 text-white px-3 py-1.5 rounded text-xs font-medium whitespace-nowrap">Identity</button>
                    <button class="text-gray-600 px-3 py-1.5 text-xs whitespace-nowrap">Prevention</button>
                    <button class="text-gray-600 px-3 py-1.5 text-xs whitespace-nowrap">Development</button>
                    <button class="text-gray-600 px-3 py-1.5 text-xs whitespace-nowrap">Inclusion</button>
                    <button class="text-gray-600 px-3 py-1.5 text-xs whitespace-nowrap">Consultations</button>
                  </div>
                </div>
                <!-- Emergency card -->
                <div class="bg-red-50 border border-red-200 rounded-xl p-4">
                  <h4 class="font-semibold text-red-800 text-sm mb-3">Emergency card</h4>
                  <div class="grid grid-cols-2 gap-3 text-xs">
                    <div>
                      <span class="text-red-600 font-medium">Allergies</span>
                      <div class="flex gap-1 mt-1">
                        <span class="bg-red-200 text-red-800 px-2 py-0.5 rounded">Peanuts</span>
                      </div>
                    </div>
                    <div>
                      <span class="text-red-600 font-medium">Chronic diseases</span>
                      <div class="flex gap-1 mt-1">
                        <span class="bg-orange-200 text-orange-800 px-2 py-0.5 rounded">Mild asthma</span>
                      </div>
                    </div>
                    <div class="col-span-2">
                      <span class="text-red-600 font-medium">Treatments</span>
                      <div class="flex gap-1 mt-1">
                        <span class="bg-blue-200 text-blue-800 px-2 py-0.5 rounded">Ventolin (as needed)</span>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- REQUESTS -->
        <div id="requests" class="scroll-mt-32">
          <div class="grid lg:grid-cols-2 gap-12 items-start">
            <!-- Requests Mockup -->
            <div class="bg-white rounded-2xl shadow-xl overflow-hidden lg:order-1">
              <div class="bg-gray-100 px-4 py-3 flex items-center gap-2 border-b">
                <div class="flex gap-1.5">
                  <div class="w-3 h-3 bg-red-400 rounded-full"></div>
                  <div class="w-3 h-3 bg-yellow-400 rounded-full"></div>
                  <div class="w-3 h-3 bg-green-400 rounded-full"></div>
                </div>
                <div class="flex-1 text-center">
                  <span class="text-xs text-gray-500">app.medsen.sn/requests</span>
                </div>
              </div>
              <div class="p-4 sm:p-6 bg-gray-50">
                <div class="flex items-center justify-between mb-4">
                  <div>
                    <h3 class="font-bold text-gray-900">Requests</h3>
                    <p class="text-xs text-gray-500">Authorization request management</p>
                  </div>
                </div>
                <!-- Stats cards -->
                <div class="grid grid-cols-2 sm:grid-cols-4 gap-2 mb-4">
                  <div class="bg-white rounded-lg p-2 sm:p-3 shadow-sm border-t-2 border-yellow-500">
                    <p class="text-[10px] sm:text-xs text-gray-500">Pending</p>
                    <p class="text-lg sm:text-xl font-bold text-yellow-600">8</p>
                  </div>
                  <div class="bg-white rounded-lg p-2 sm:p-3 shadow-sm border-t-2 border-blue-500">
                    <p class="text-[10px] sm:text-xs text-gray-500">Under review</p>
                    <p class="text-lg sm:text-xl font-bold text-blue-600">3</p>
                  </div>
                  <div class="bg-white rounded-lg p-2 sm:p-3 shadow-sm border-t-2 border-green-500">
                    <p class="text-[10px] sm:text-xs text-gray-500">Approved</p>
                    <p class="text-lg sm:text-xl font-bold text-green-600">24</p>
                  </div>
                  <div class="bg-white rounded-lg p-2 sm:p-3 shadow-sm border-t-2 border-red-500">
                    <p class="text-[10px] sm:text-xs text-gray-500">Rejected</p>
                    <p class="text-lg sm:text-xl font-bold text-red-600">2</p>
                  </div>
                </div>
                <!-- Table -->
                <div class="bg-white rounded-lg shadow-sm overflow-x-auto">
                  <table class="w-full text-xs min-w-[400px]">
                    <thead class="bg-gray-50 text-gray-500">
                      <tr>
                        <th class="px-2 sm:px-3 py-2 text-left">Student</th>
                        <th class="px-2 sm:px-3 py-2 text-left">Type</th>
                        <th class="px-2 sm:px-3 py-2 text-left">Priority</th>
                        <th class="px-2 sm:px-3 py-2 text-left">Status</th>
                      </tr>
                    </thead>
                    <tbody class="divide-y">
                      <tr>
                        <td class="px-2 sm:px-3 py-2 font-medium whitespace-nowrap">Ndiaye Aminata</td>
                        <td class="px-2 sm:px-3 py-2">PAI</td>
                        <td class="px-2 sm:px-3 py-2"><span class="bg-red-100 text-red-700 px-2 py-0.5 rounded-full whitespace-nowrap">Emergency</span></td>
                        <td class="px-2 sm:px-3 py-2"><span class="bg-yellow-100 text-yellow-700 px-2 py-0.5 rounded-full whitespace-nowrap">Pending</span></td>
                      </tr>
                      <tr>
                        <td class="px-2 sm:px-3 py-2 font-medium whitespace-nowrap">Sow Ibrahima</td>
                        <td class="px-2 sm:px-3 py-2">Authorization</td>
                        <td class="px-2 sm:px-3 py-2"><span class="bg-orange-100 text-orange-700 px-2 py-0.5 rounded-full whitespace-nowrap">High</span></td>
                        <td class="px-2 sm:px-3 py-2"><span class="bg-blue-100 text-blue-700 px-2 py-0.5 rounded-full whitespace-nowrap">Under review</span></td>
                      </tr>
                      <tr>
                        <td class="px-2 sm:px-3 py-2 font-medium whitespace-nowrap">Diop Ousmane</td>
                        <td class="px-2 sm:px-3 py-2">Accommodation</td>
                        <td class="px-2 sm:px-3 py-2"><span class="bg-gray-100 text-gray-700 px-2 py-0.5 rounded-full whitespace-nowrap">Medium</span></td>
                        <td class="px-2 sm:px-3 py-2"><span class="bg-green-100 text-green-700 px-2 py-0.5 rounded-full whitespace-nowrap">Approved</span></td>
                      </tr>
                    </tbody>
                  </table>
                </div>
              </div>
            </div>
            <div class="lg:order-2">
              <div class="inline-flex items-center gap-2 bg-purple-100 text-purple-700 text-sm font-semibold px-4 py-2 rounded-full mb-4">
                <span class="w-2 h-2 bg-purple-500 rounded-full"></span>
                {features[1].cide}
              </div>
              <h2 class="text-3xl font-bold text-gray-900 mb-4">{features[1].titre}</h2>
              <p class="text-lg text-gray-600 mb-6">{features[1].description}</p>
              <ul class="space-y-3 mb-6">
                {features[1].details.map((detail) => (
                  <li class="flex items-start gap-3">
                    <svg class="w-5 h-5 text-purple-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                    </svg>
                    <span class="text-gray-700">{detail}</span>
                  </li>
                ))}
              </ul>
              <div class="flex flex-wrap gap-2">
                {features[1].roles.map((role) => (
                  <span class="bg-gray-200 text-gray-700 text-xs font-medium px-3 py-1 rounded-full">{role}</span>
                ))}
              </div>
            </div>
          </div>
        </div>

        <!-- CONSULTATIONS -->
        <div id="consultations" class="scroll-mt-32">
          <div class="grid lg:grid-cols-2 gap-12 items-start">
            <div>
              <div class="inline-flex items-center gap-2 bg-blue-100 text-blue-700 text-sm font-semibold px-4 py-2 rounded-full mb-4">
                <span class="w-2 h-2 bg-blue-500 rounded-full"></span>
                {features[2].cide}
              </div>
              <h2 class="text-3xl font-bold text-gray-900 mb-4">{features[2].titre}</h2>
              <p class="text-lg text-gray-600 mb-6">{features[2].description}</p>
              <ul class="space-y-3 mb-6">
                {features[2].details.map((detail) => (
                  <li class="flex items-start gap-3">
                    <svg class="w-5 h-5 text-blue-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                    </svg>
                    <span class="text-gray-700">{detail}</span>
                  </li>
                ))}
              </ul>
              <div class="flex flex-wrap gap-2">
                {features[2].roles.map((role) => (
                  <span class="bg-gray-200 text-gray-700 text-xs font-medium px-3 py-1 rounded-full">{role}</span>
                ))}
              </div>
            </div>
            <!-- Consultations Mockup -->
            <div class="bg-white rounded-2xl shadow-xl overflow-hidden">
              <div class="bg-gray-100 px-4 py-3 flex items-center gap-2 border-b">
                <div class="flex gap-1.5">
                  <div class="w-3 h-3 bg-red-400 rounded-full"></div>
                  <div class="w-3 h-3 bg-yellow-400 rounded-full"></div>
                  <div class="w-3 h-3 bg-green-400 rounded-full"></div>
                </div>
                <div class="flex-1 text-center">
                  <span class="text-xs text-gray-500">app.medsen.sn/consultations</span>
                </div>
              </div>
              <div class="p-4 sm:p-6 bg-gray-50">
                <div class="flex items-center justify-between mb-4">
                  <div>
                    <h3 class="font-bold text-gray-900">Consultations</h3>
                    <p class="text-xs text-gray-500">History and medical follow-up</p>
                  </div>
                  <button class="bg-blue-600 text-white text-xs px-3 py-1.5 rounded-lg">+ New</button>
                </div>
                <!-- Filters -->
                <div class="grid grid-cols-1 sm:grid-cols-3 gap-2 mb-4">
                  <input type="text" placeholder="Search..." class="text-xs px-3 py-2 border rounded-lg bg-white" />
                  <select class="text-xs px-3 py-2 border rounded-lg bg-white text-gray-600">
                    <option>All types</option>
                  </select>
                  <select class="text-xs px-3 py-2 border rounded-lg bg-white text-gray-600">
                    <option>All statuses</option>
                  </select>
                </div>
                <!-- Table -->
                <div class="bg-white rounded-lg shadow-sm overflow-x-auto">
                  <table class="w-full text-xs min-w-[500px]">
                    <thead class="bg-gray-50 text-gray-500">
                      <tr>
                        <th class="px-2 sm:px-3 py-2 text-left">Date</th>
                        <th class="px-2 sm:px-3 py-2 text-left">Student</th>
                        <th class="px-2 sm:px-3 py-2 text-left">Type</th>
                        <th class="px-2 sm:px-3 py-2 text-left">Reason</th>
                        <th class="px-2 sm:px-3 py-2 text-left">Status</th>
                      </tr>
                    </thead>
                    <tbody class="divide-y">
                      <tr>
                        <td class="px-2 sm:px-3 py-2">
                          <div class="font-medium whitespace-nowrap">01/22/2026</div>
                          <div class="text-gray-400">09:30</div>
                        </td>
                        <td class="px-2 sm:px-3 py-2">
                          <div class="font-medium text-blue-600 whitespace-nowrap">Diallo Awa</div>
                          <div class="text-gray-400">5th grade</div>
                        </td>
                        <td class="px-2 sm:px-3 py-2"><span class="bg-blue-100 text-blue-700 px-2 py-0.5 rounded-full whitespace-nowrap">Appointment</span></td>
                        <td class="px-2 sm:px-3 py-2 whitespace-nowrap">Asthma follow-up - PAI</td>
                        <td class="px-2 sm:px-3 py-2"><span class="bg-green-100 text-green-700 px-2 py-0.5 rounded-full whitespace-nowrap">Completed</span></td>
                      </tr>
                      <tr>
                        <td class="px-2 sm:px-3 py-2">
                          <div class="font-medium whitespace-nowrap">01/22/2026</div>
                          <div class="text-gray-400">10:15</div>
                        </td>
                        <td class="px-2 sm:px-3 py-2">
                          <div class="font-medium text-blue-600 whitespace-nowrap">Ndiaye Moussa</div>
                          <div class="text-gray-400">CM2</div>
                        </td>
                        <td class="px-2 sm:px-3 py-2"><span class="bg-red-100 text-red-700 px-2 py-0.5 rounded-full whitespace-nowrap">Emergency</span></td>
                        <td class="px-2 sm:px-3 py-2 whitespace-nowrap">Fall - Knee wound</td>
                        <td class="px-2 sm:px-3 py-2"><span class="bg-green-100 text-green-700 px-2 py-0.5 rounded-full whitespace-nowrap">Completed</span></td>
                      </tr>
                      <tr>
                        <td class="px-2 sm:px-3 py-2">
                          <div class="font-medium whitespace-nowrap">01/23/2026</div>
                          <div class="text-gray-400">08:45</div>
                        </td>
                        <td class="px-2 sm:px-3 py-2">
                          <div class="font-medium text-blue-600 whitespace-nowrap">Sow Fatou</div>
                          <div class="text-gray-400">CE2</div>
                        </td>
