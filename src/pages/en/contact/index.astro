---
import Layout from '../../../layouts/Layout.astro';
---

<Layout title="Contact" lang="en">
  <!-- Hero -->
  <section class="bg-gradient-to-br from-sante-600 to-sante-700 text-white py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <span class="inline-block bg-white/20 text-sm font-semibold px-4 py-2 rounded-full mb-6">
          Let's talk
        </span>
        <h1 class="text-4xl sm:text-5xl font-extrabold mb-6">
          Contact Us
        </h1>
        <p class="text-xl text-white/90">
          Interested in MEDSEN? Public decision-maker, potential partner, or simply curious, we're here to listen.
        </p>
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-16">
        <!-- Form -->
        <div>
          <h2 class="text-2xl font-bold text-gray-900 mb-6">
            Send us a message
          </h2>
          <form class="space-y-6" action="https://api.web3forms.com/submit" method="POST">
            <input type="hidden" name="access_key" value="70db9a76-6678-42d0-ab37-198bb3fe3ef9" />
            <input type="hidden" name="subject" value="New message from medsen.sn (EN)" />
            <input type="hidden" name="from_name" value="MEDSEN Contact" />
            <input type="hidden" name="redirect" value="https://medsen.sn/en/contact/thank-you" />
            <input type="checkbox" name="botcheck" class="hidden" style="display: none;" />
            <div class="grid sm:grid-cols-2 gap-6">
              <div>
                <label for="nom" class="block text-sm font-medium text-gray-700 mb-2">Last Name *</label>
                <input
                  type="text"
                  id="nom"
                  name="nom"
                  required
                  class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-sante-500 focus:border-sante-500 transition-colors"
                  placeholder="Your last name"
                />
              </div>
              <div>
                <label for="prenom" class="block text-sm font-medium text-gray-700 mb-2">First Name *</label>
                <input
                  type="text"
                  id="prenom"
                  name="prenom"
                  required
                  class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-sante-500 focus:border-sante-500 transition-colors"
                  placeholder="Your first name"
                />
              </div>
            </div>

            <div>
              <label for="email" class="block text-sm font-medium text-gray-700 mb-2">Email *</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-sante-500 focus:border-sante-500 transition-colors"
                placeholder="votre@email.com"
              />
            </div>

            <div>
              <label for="organisation" class="block text-sm font-medium text-gray-700 mb-2">Organisation</label>
              <input
                type="text"
                id="organisation"
                name="organisation"
                class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-sante-500 focus:border-sante-500 transition-colors"
                placeholder="Ministry, NGO, Company..."
              />
            </div>

            <div>
              <label for="sujet" class="block text-sm font-medium text-gray-700 mb-2">Subject *</label>
              <select
                id="sujet"
                name="sujet"
                required
                class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-sante-500 focus:border-sante-500 transition-colors bg-white"
              >
                <option value="">Select a subject</option>
                <option value="demo">Demo request</option>
                <option value="partenariat">Partnership proposal</option>
                <option value="information">Information request</option>
                <option value="presse">Press contact</option>
                <option value="autre">Other</option>
              </select>
            </div>

            <div>
              <label for="message" class="block text-sm font-medium text-gray-700 mb-2">Message *</label>
              <textarea
                id="message"
                name="message"
                rows="5"
                required
                class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-sante-500 focus:border-sante-500 transition-colors resize-none"
                placeholder="Describe your request..."
              ></textarea>
            </div>

            <button
              type="submit"
              class="w-full bg-sante-500 hover:bg-sante-600 text-white px-8 py-4 rounded-xl font-semibold text-lg transition-colors"
            >
              Send message
            </button>
          </form>
        </div>

        <!-- Information -->
        <div>
          <h2 class="text-2xl font-bold text-gray-900 mb-6">
            Other ways to reach us
          </h2>

          <div class="space-y-8">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-sante-100 rounded-xl flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-sante-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-gray-900 mb-1">Email</h3>
                <p class="text-gray-600">ndeyetalla.dioum@medsen.sn</p>
                <p class="text-sm text-gray-500 mt-1">Response within 48 business hours</p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-blue-100 rounded-xl flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-gray-900 mb-1">Phone</h3>
                <p class="text-gray-600">+221 77 845 88 02</p>
                <p class="text-sm text-gray-500 mt-1">Mon-Sat, 8am-8pm (GMT)</p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-purple-100 rounded-xl flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-gray-900 mb-1">Address</h3>
                <p class="text-gray-600">Dakar, Senegal</p>
                <p class="text-sm text-gray-500 mt-1">By appointment only</p>
              </div>
            </div>
          </div>

          <!-- Demo CTA -->
          <div class="mt-12 bg-gradient-to-br from-sante-50 to-sante-100 rounded-2xl p-8">
            <h3 class="text-xl font-bold text-gray-900 mb-4">
              Request a demonstration
            </h3>
            <p class="text-gray-600 mb-6">
              Want to see MEDSEN in action? We organize personalized demonstrations
              for decision-makers and potential partners.
            </p>
            <ul class="space-y-3 mb-6">
              <li class="flex items-center gap-2 text-gray-700">
                <svg class="w-5 h-5 text-sante-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                Complete platform presentation
              </li>
              <li class="flex items-center gap-2 text-gray-700">
                <svg class="w-5 h-5 text-sante-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                Answers to your technical questions
              </li>
              <li class="flex items-center gap-2 text-gray-700">
                <svg class="w-5 h-5 text-sante-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                Discussion on deployment options
              </li>
            </ul>
            <p class="text-sm text-gray-500">
              Select "Demo request" in the form opposite.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Quick FAQ -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-gray-900 mb-8 text-center">
        Frequently Asked Questions
      </h2>

      <div class="space-y-6">
        <div class="bg-white rounded-xl p-6 shadow-sm">
          <h3 class="font-semibold text-gray-900 mb-2">Is MEDSEN already deployed?</h3>
          <p class="text-gray-600">
            MEDSEN is currently in the final development phase. We are looking for partners
            for a pilot deployment before nationwide rollout.
          </p>
        </div>

        <div class="bg-white rounded-xl p-6 shadow-sm">
          <h3 class="font-semibold text-gray-900 mb-2">What is the business model?</h3>
          <p class="text-gray-600">
            We are open to different arrangements: public-private partnership, funding
            from international donors (UNICEF, WHO), or direct acquisition by the State.
          </p>
        </div>

        <div class="bg-white rounded-xl p-6 shadow-sm">
          <h3 class="font-semibold text-gray-900 mb-2">Is the data secure?</h3>
          <p class="text-gray-600">
            Absolutely. MEDSEN is designed with the highest security standards: encryption,
            strict access control, audit trail, and sovereign hosting options.
          </p>
        </div>

        <div class="bg-white rounded-xl p-6 shadow-sm">
          <h3 class="font-semibold text-gray-900 mb-2">How can I support the project?</h3>
          <p class="text-gray-600">
            Contact us! Whether you are a decision-maker who can facilitate adoption, a technical
            partner, or a funder, your support is invaluable.
          </p>
        </div>
      </div>
    </div>
  </section>
</Layout>
