---
import Layout from '../../../layouts/Layout.astro';
---

<Layout title="Legal Notices" lang="en">
  <section class="py-20 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl font-bold text-gray-900 mb-8">Legal Notices</h1>

      <div class="bg-white rounded-2xl p-8 shadow-sm space-y-8">
        <section>
          <h2 class="text-2xl font-bold text-gray-900 mb-4">Website Publisher</h2>
          <p class="text-gray-600">
            <strong>MEDSEN</strong><br />
            Senegal's national school health platform<br />
            Dakar, Senegal<br />
            Email: ndeyetalla.dioum@medsen.sn<br />
            Tel: +221 77 845 88 02
          </p>
        </section>

        <section>
          <h2 class="text-2xl font-bold text-gray-900 mb-4">Publication Director</h2>
          <p class="text-gray-600">
            The publication director is the legal representative of MEDSEN.
          </p>
        </section>

        <section>
          <h2 class="text-2xl font-bold text-gray-900 mb-4">Hosting</h2>
          <p class="text-gray-600">
            This website is hosted by:<br />
            [Host name]<br />
            [Host address]
          </p>
        </section>

        <section>
          <h2 class="text-2xl font-bold text-gray-900 mb-4">Intellectual Property</h2>
          <p class="text-gray-600 mb-4">
            This entire website is governed by Senegalese and international copyright
            and intellectual property law. All reproduction rights are reserved, including
            for downloadable documents and iconographic and photographic representations.
          </p>
          <p class="text-gray-600">
            The reproduction of all or part of this website on any electronic or other medium is strictly
            prohibited without the express authorization of the publication director.
          </p>
        </section>

        <section>
          <h2 class="text-2xl font-bold text-gray-900 mb-4">Credits</h2>
          <p class="text-gray-600">
            Design and development: MEDSEN Team<br />
            Design: MEDSEN Team
          </p>
        </section>

        <section>
          <h2 class="text-2xl font-bold text-gray-900 mb-4">Legal Framework</h2>
          <p class="text-gray-600 mb-4">
            MEDSEN operates within the framework of:
          </p>
          <ul class="list-disc list-inside text-gray-600 space-y-2">
            <li>The International Convention on the Rights of the Child (CRC), ratified by Senegal in 1990</li>
            <li>The Plan Senegal Emergent (PSE)</li>
            <li>The United Nations Sustainable Development Goals (SDGs)</li>
            <li>The Senegalese personal data protection law</li>
          </ul>
        </section>

        <section>
          <h2 class="text-2xl font-bold text-gray-900 mb-4">Contact</h2>
          <p class="text-gray-600">
            For any questions regarding these legal notices, you can contact us at:<br />
            <a href="mailto:ndeyetalla.dioum@medsen.sn" class="text-sante-600 hover:underline">ndeyetalla.dioum@medsen.sn</a><br />
            Tel: <a href="tel:+221778458802" class="text-sante-600 hover:underline">+221 77 845 88 02</a>
          </p>
        </section>
      </div>
    </div>
  </section>
</Layout>
