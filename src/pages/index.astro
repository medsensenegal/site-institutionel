---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Accueil">
  <!-- Hero -->
  <section class="relative bg-gradient-to-br from-sante-600 via-sante-500 to-sante-400 text-white overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <svg class="w-full h-full" viewBox="0 0 100 100" preserveAspectRatio="none">
        <defs>
          <pattern id="grid" width="10" height="10" patternUnits="userSpaceOnUse">
            <path d="M 10 0 L 0 0 0 10" fill="none" stroke="white" stroke-width="0.5"/>
          </pattern>
        </defs>
        <rect width="100%" height="100%" fill="url(#grid)" />
      </svg>
    </div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 lg:py-28">
      <div class="max-w-3xl">
        <div class="inline-flex items-center gap-2 bg-white/20 backdrop-blur-sm rounded-full px-4 py-2 mb-6">
          <span class="w-2 h-2 bg-senegal-yellow rounded-full animate-pulse"></span>
          <span class="text-sm font-medium">Éditeur sénégalais · Solution B2G</span>
        </div>

        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold leading-tight mb-6">
          La santé scolaire,<br/>
          <span class="text-senegal-yellow">pilotée comme un système.</span>
        </h1>

        <p class="text-xl text-white/90 mb-8 max-w-2xl">
          Une solution numérique pour les ministères, institutions et opérateurs pour déployer
          et piloter une politique nationale de santé scolaire — de la prévention au suivi
          individualisé.
        </p>

        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/demo" class="bg-white text-sante-600 hover:bg-gray-100 px-7 py-3.5 rounded-xl font-semibold transition-colors text-center">
            Demander une démo
          </a>
          <a href="/fonctionnalites" class="border-2 border-white text-white hover:bg-white/10 px-7 py-3.5 rounded-xl font-semibold transition-colors text-center">
            Découvrir la solution
          </a>
        </div>
      </div>
    </div>

    <div class="absolute bottom-0 left-0 right-0">
      <svg viewBox="0 0 1440 120" fill="none">
        <path d="M0 120L60 110C120 100 240 80 360 70C480 60 600 60 720 65C840 70 960 80 1080 85C1200 90 1320 90 1380 90L1440 90V120H1380C1320 120 1200 120 1080 120C960 120 840 120 720 120C600 120 480 120 360 120C240 120 120 120 60 120H0Z" fill="white"/>
      </svg>
    </div>
  </section>

  <!-- Constat / Réponse -->
  <section class="py-20 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-10">
        <div class="border-l-4 border-red-400 pl-6">
          <div class="text-sm font-semibold text-red-600 uppercase tracking-wider mb-2">Le constat</div>
          <p class="text-2xl font-bold text-gray-900 leading-snug">
            La santé scolaire africaine reste suivie sur papier, sans vision consolidée.
          </p>
        </div>
        <div class="border-l-4 border-sante-500 pl-6">
          <div class="text-sm font-semibold text-sante-600 uppercase tracking-wider mb-2">La réponse</div>
          <p class="text-2xl font-bold text-gray-900 leading-snug">
            Une plateforme SaaS clé en main, pensée pour le déploiement national.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Pour qui (teaser) -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-end justify-between mb-10 gap-6 flex-wrap">
        <div>
          <div class="text-sm font-semibold text-sante-600 uppercase tracking-wider mb-2">Pour qui</div>
          <h2 class="text-3xl sm:text-4xl font-bold text-gray-900">Une solution pour trois types d'acheteurs.</h2>
        </div>
        <a href="/nos-missions" class="text-sante-600 hover:text-sante-700 font-semibold flex items-center gap-2">
          Voir le détail
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>

      <div class="grid md:grid-cols-3 gap-4">
        <a href="/nos-missions#ministeres" class="block bg-white rounded-2xl p-6 hover:shadow-md transition-shadow border border-gray-100">
          <div class="w-10 h-10 bg-senegal-green/10 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-senegal-green" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 21h18M3 10h18M5 6l7-3 7 3M4 10v11m16-11v11"/></svg>
          </div>
          <h3 class="font-bold text-gray-900 mb-1">Ministères & gouvernements</h3>
          <p class="text-sm text-gray-600">Couverture nationale, indicateurs consolidés, solution SaaS cloud.</p>
        </a>
        <a href="/nos-missions#bailleurs" class="block bg-white rounded-2xl p-6 hover:shadow-md transition-shadow border border-gray-100">
          <div class="w-10 h-10 bg-blue-100 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <h3 class="font-bold text-gray-900 mb-1">Bailleurs & institutions</h3>
          <p class="text-sm text-gray-600">Cofinancement de programmes, indicateurs ODD, reporting structuré.</p>
        </a>
        <a href="/nos-missions#ong" class="block bg-white rounded-2xl p-6 hover:shadow-md transition-shadow border border-gray-100">
          <div class="w-10 h-10 bg-purple-100 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M9 12a3 3 0 100-6 3 3 0 000 6z"/></svg>
          </div>
          <h3 class="font-bold text-gray-900 mb-1">ONG & réseaux d'écoles</h3>
          <p class="text-sm text-gray-600">Multi-établissements, suivi opérationnel, rapports bailleurs.</p>
        </a>
      </div>
    </div>
  </section>

  <!-- Solution (teaser 4 fonctionnalités) -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-end justify-between mb-10 gap-6 flex-wrap">
        <div>
          <div class="text-sm font-semibold text-sante-600 uppercase tracking-wider mb-2">La solution</div>
          <h2 class="text-3xl sm:text-4xl font-bold text-gray-900">Quatre piliers fonctionnels.</h2>
        </div>
        <a href="/fonctionnalites" class="text-sante-600 hover:text-sante-700 font-semibold flex items-center gap-2">
          Toutes les fonctionnalités
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-4">
        <div class="bg-gray-50 rounded-2xl p-6">
          <div class="w-10 h-10 bg-sante-100 rounded-lg flex items-center justify-center mb-3">
            <svg class="w-5 h-5 text-sante-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2"/></svg>
          </div>
          <h3 class="font-bold text-gray-900 mb-1">Dossier Santé Unique</h3>
          <p class="text-sm text-gray-600">Un dossier numérique par élève, de la maternelle au lycée.</p>
        </div>
        <div class="bg-gray-50 rounded-2xl p-6">
          <div class="w-10 h-10 bg-blue-100 rounded-lg flex items-center justify-center mb-3">
            <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21"/></svg>
          </div>
          <h3 class="font-bold text-gray-900 mb-1">Campagnes</h3>
          <p class="text-sm text-gray-600">Vaccination, dépistages, suivi nutritionnel et bucco-dentaire.</p>
        </div>
        <div class="bg-gray-50 rounded-2xl p-6">
          <div class="w-10 h-10 bg-purple-100 rounded-lg flex items-center justify-center mb-3">
            <svg class="w-5 h-5 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"/></svg>
          </div>
          <h3 class="font-bold text-gray-900 mb-1">Workflow École–IME</h3>
          <p class="text-sm text-gray-600">Circuit fluide entre établissements et inspections médicales.</p>
        </div>
        <div class="bg-gray-50 rounded-2xl p-6">
          <div class="w-10 h-10 bg-amber-100 rounded-lg flex items-center justify-center mb-3">
            <svg class="w-5 h-5 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10"/></svg>
          </div>
          <h3 class="font-bold text-gray-900 mb-1">Pilotage</h3>
          <p class="text-sm text-gray-600">Tableaux de bord locaux, régionaux et nationaux temps réel.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Crédibilité : DCMS + témoignage condensé -->
  <section class="py-20 bg-gradient-to-r from-sante-50 via-white to-senegal-yellow/10">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-8 items-center">
        <div class="bg-white rounded-2xl p-7 shadow-sm border-l-4 border-senegal-green">
          <div class="text-xs font-semibold text-senegal-green uppercase tracking-wider mb-2">Charte de projet signée</div>
          <h3 class="text-lg font-bold text-gray-900 mb-2">Division du Contrôle Médical Scolaire (DCMS)</h3>
          <p class="text-gray-600 text-sm">
            Charte signée avec la DCMS du Ministère de l'Éducation Nationale du Sénégal,
            validant la démarche et les objectifs.
          </p>
        </div>
        <div class="bg-white rounded-2xl p-7 shadow-sm border-l-4 border-sante-500">
          <div class="text-xs font-semibold text-sante-600 uppercase tracking-wider mb-2">Co-conçu avec le terrain</div>
          <p class="text-gray-700 italic mb-3">
            « C'est exactement ce qu'il nous faut. MEDSEN va transformer notre façon de travailler. »
          </p>
          <p class="text-sm text-gray-500">— Dr Fatou Fall SYLLA, Chef IME Dakar</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Ambition continentale -->
  <section class="py-20 bg-gradient-to-br from-sante-700 to-sante-800 text-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="text-sm font-semibold text-senegal-yellow uppercase tracking-wider mb-4">Ambition</div>
      <h2 class="text-3xl sm:text-4xl font-bold mb-6">
        Conçu au Sénégal, pensé pour passer à l'échelle continentale.
      </h2>
      <p class="text-lg text-white/85 max-w-3xl mx-auto mb-10">
        Architecture multi-tenant, multi-langues, paramétrable selon les systèmes éducatifs
        et programmes nationaux d'immunisation.
      </p>
      <div class="inline-block bg-white/10 backdrop-blur-lg rounded-2xl px-10 py-6 border border-white/20">
        <div class="text-5xl font-extrabold text-senegal-yellow">500M+</div>
        <div class="text-white/80 text-sm mt-1">enfants en âge scolaire en Afrique</div>
      </div>
    </div>
  </section>

  <!-- Fondation teaser -->
  <section class="py-20 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="inline-flex items-center gap-2 bg-amber-100 text-amber-800 text-sm font-semibold px-4 py-2 rounded-full mb-4">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.293z"/></svg>
        Fondation MEDSEN
      </div>
      <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-4">
        Une entreprise, et un engagement.
      </h2>
      <p class="text-lg text-gray-600 mb-6">
        Au-delà de la solution, nous portons un engagement pour les droits de l'enfant
        à travers la Fondation MEDSEN, ancrée dans la CIDE.
      </p>
      <a href="/fondation" class="inline-flex items-center gap-2 text-amber-700 hover:text-amber-800 font-semibold">
        En savoir plus
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-sante-600">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl sm:text-4xl font-bold text-white mb-8">
        Vous pilotez la santé scolaire ? Parlons-nous.
      </h2>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/demo" class="bg-white text-sante-600 hover:bg-gray-100 px-7 py-3.5 rounded-xl font-semibold transition-colors">
          Demander une démo
        </a>
        <a href="/contact" class="border-2 border-white text-white hover:bg-white/10 px-7 py-3.5 rounded-xl font-semibold transition-colors">
          Demander un devis
        </a>
      </div>
    </div>
  </section>
</Layout>
